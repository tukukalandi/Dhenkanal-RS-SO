rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDocument(data) {
      return data.productId in ['Savings', 'PLI/RPLI', 'Domestic Mails', 'International Mails', 'Parcels', 'BD/CCS'] &&
             data.fileName is string && data.fileName.size() <= 256 &&
             data.fileLink is string && data.fileLink.size() <= 1024 &&
             data.createdAt is timestamp;
    }

    // Documents collection
    match /documents/{docId} {
      allow read: if true; // Public portal access
      
      allow create: if isSignedIn() && 
                    isValidId(docId) && 
                    isValidDocument(request.resource.data) &&
                    request.resource.data.uploadedBy == request.auth.uid &&
                    request.resource.data.createdAt == request.time;

      allow update: if isSignedIn() &&
                    isValidDocument(request.resource.data) &&
                    request.resource.data.uploadedBy == request.auth.uid &&
                    request.resource.data.uploadedBy == resource.data.uploadedBy &&
                    request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isSignedIn() && resource.data.uploadedBy == request.auth.uid;
    }
  }
}
