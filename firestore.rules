rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email != null && request.auth.token.email.lower() == 'tukukalandi@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDocument(data) {
      return data.productId in ['Savings', 'PLI/RPLI', 'Domestic Mails', 'International Mails', 'Parcels', 'BD/CCS', 'PO Orders/Rules', 'Official Documents', 'Others'] &&
             data.fileName is string && data.fileName.size() <= 256 &&
             data.fileLink is string && data.fileLink.size() <= 1024 &&
             data.uploadedBy == request.auth.uid &&
             data.createdAt == request.time &&
             (data.subCategory == null || (data.subCategory is string && data.subCategory.size() <= 128)) &&
             (data.description == null || (data.description is string && data.description.size() <= 2048)) &&
             (data.driveFileId == null || (data.driveFileId is string && data.driveFileId.size() <= 256));
    }

    // Documents collection
    match /documents/{docId} {
      allow read: if true; // Public portal access
      
      allow create: if isSignedIn() && 
                    isValidDocument(request.resource.data) &&
                    request.resource.data.keys().hasAll(['productId', 'fileName', 'fileLink', 'uploadedBy', 'createdAt']) &&
                    request.resource.data.keys().size() <= 8;

      allow update: if isSignedIn() && (
                    isAdmin() || 
                    (resource.data.uploadedBy == request.auth.uid && 
                     isValidDocument(request.resource.data) &&
                     request.resource.data.uploadedBy == resource.data.uploadedBy &&
                     request.resource.data.createdAt == resource.data.createdAt)
                  );
      
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uploadedBy == request.auth.uid);
    }
  }
}
